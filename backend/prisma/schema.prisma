generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------Enums---------------------------------------------------

enum Role {
  ADMIN
  PROJECT_MANAGER
  CONSULTANT_MANAGER
  CONSULTANT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LOCKED
}

enum TokenType {
  ACTIVATION
  PASSWORD_RESET
  REFRESH
}

enum AuditOutcome {
  SUCCESS
  USER_NOT_FOUND
  ACCOUNT_PENDING
  ACCOUNT_SUSPENDED
  ACCOUNT_LOCKED
  FAILED_PASSWORD
}

enum CompetencyLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum PlacementStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum ConsultantAvailability {
  AVAILABLE
  UNAVAILABLE
  ON_LEAVE
}

// ---------------------------------------- RBAC Models------------------------------------

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RoleDefinition {
  id          String   @id @default(uuid())
  name        Role     @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

// RolePermission — join table mapping which permissions belong to which role.
model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       RoleDefinition @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------- Models -----------------------------

model User {
  id                 String          @id @default(uuid())
  fullName           String
  email              String          @unique
  passwordHash       String?
  role               Role
  roleId             String?         @map("role_id")
  roleDefinition     RoleDefinition? @relation(fields: [roleId], references: [id])
  status             UserStatus      @default(PENDING)
  failedAttempts     Int             @default(0)
  lockedUntil        DateTime?
  isLocked           Boolean         @default(false)
  termsAcceptedAt    DateTime?
  tenantId           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tokens             Token[]
  auditLogs          authAuditLog[]
  consultant         Consultant?
  managedProjects    ProjectManager[]
  managedConsultants ConsultantManager[]

  @@map("users")
}

model Token {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  familyId  String?   // groups rotated refresh tokens from the same login session

  @@map("tokens")
}

model Consultant {
  id            String                 @id @default(uuid())
  userId        String                 @unique
  user          User                   @relation(fields: [userId], references: [id])
  location      String
  costToCompany Float
  availability  ConsultantAvailability @default(AVAILABLE)
  tenantId      String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  skills       ConsultantSkill[]
  certificates Certificate[]
  placements   ProjectPlacement[]
  cvFiles      CvFile[]
  managers     ConsultantManager[]

  @@map("consultants")
}

model ConsultantManager {
  id           String     @id @default(uuid())
  userId       String
  consultantId String
  user         User       @relation(fields: [userId], references: [id])
  consultant   Consultant @relation(fields: [consultantId], references: [id])
  assignedAt   DateTime   @default(now())

  @@unique([userId, consultantId])
  @@map("consultant_managers")
}

model Skill {
  id               String          @id @default(uuid())
  name             String          @unique
  category         String
  tenantId         String?

  consultantSkills ConsultantSkill[]
  projectSkills    ProjectSkill[]

  @@map("skills")
}

model ConsultantSkill {
  id              String          @id @default(uuid())
  consultantId    String
  skillId         String
  competencyLevel CompetencyLevel
  yearsExperience Int
  confidenceLevel Int
  consultant      Consultant      @relation(fields: [consultantId], references: [id])
  skill           Skill           @relation(fields: [skillId], references: [id])

  @@unique([consultantId, skillId])
  @@map("consultant_skills")
}

model Certificate {
  id           String     @id @default(uuid())
  consultantId String
  title        String
  issuingBody  String
  uploadedAt   DateTime   @default(now())
  consultant   Consultant @relation(fields: [consultantId], references: [id])

  @@map("certificates")
}

model CvFile {
  id           String     @id @default(uuid())
  consultantId String
  fileName     String
  mimeType     String
  fileData     Bytes
  status       String     @default("PENDING")
  uploadedAt   DateTime   @default(now())
  consultant   Consultant @relation(fields: [consultantId], references: [id])

  @@map("cv_files")
}

model Project {
  id                           String        @id @default(uuid())
  projectName                  String
  clientName                   String
  city                         String
  province                     String
  startDate                    DateTime
  endDate                      DateTime?
  teamSize                     Int
  requiredAllocationPercentage Int
  clientBillingBudget          Float
  status                       ProjectStatus @default(OPEN)
  tenantId                     String?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt

  skills     ProjectSkill[]
  managers   ProjectManager[]
  placements ProjectPlacement[]

  @@map("projects")
}

model ProjectSkill {
  id                String          @id @default(uuid())
  projectId         String
  skillId           String
  minimumCompetency CompetencyLevel
  isMandatory       Boolean         @default(true)
  project           Project         @relation(fields: [projectId], references: [id])
  skill             Skill           @relation(fields: [skillId], references: [id])

  @@unique([projectId, skillId])
  @@map("project_skills")
}

model ProjectManager {
  id        String  @id @default(uuid())
  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@map("project_managers")
}

model ProjectPlacement {
  id           String          @id @default(uuid())
  projectId    String
  consultantId String
  startDate    DateTime
  endDate      DateTime?
  allocation   Int
  status       PlacementStatus @default(ACTIVE)
  createdAt    DateTime        @default(now())
  project      Project         @relation(fields: [projectId], references: [id])
  consultant   Consultant      @relation(fields: [consultantId], references: [id])

  @@map("project_placements")
}

model authAuditLog {
  id        String       @id @default(uuid())
  email     String
  outcome   AuditOutcome
  userId    String?
  ipAddress String
  userAgent String?
  timestamp DateTime     @default(now())

  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("auth_audit_logs")
}