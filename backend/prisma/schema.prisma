// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement()) @map("userID")
  roleID      Int
  name        String
  surname     String
  idNumber    String       @map("IDNumber")
  email       String       @unique
  phoneNumber String       @map("PhoneNumber")
  hashedPassword String
  tokens      String?
  tokenExpiry    DateTime?
  status         UserStatus   @default(Available)
  acceptedTsAndCs Boolean     @default(false)
  role        Role         @relation(fields: [roleID], references: [id])
  consultant  Consultant?
  managers    ProjectManager[]
}

enum UserStatus {
  Available
  Unavailable
  onLeave
}
model Role {
  id          Int              @id @default(autoincrement()) @map("roleID")
  title       String
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement()) @map("permissionID")
  title       String
}

model RolePermission {
  permissionID Int
  roleID       Int
  role         Role       @relation(fields: [roleID], references: [id])
  @@id([permissionID, roleID])
  @@map("role_permission")
}

model Consultant {
  id           Int                @id @default(autoincrement()) @map("consultantID")
  userID       Int                @unique @map("UserID")
  availability Boolean
  location     String
  user         User               @relation(fields: [userID], references: [id])
  certificates Certificate[]
  skills       ConsultantSkills[]
  placements   ProjectPlacement[]
}

model Certificate {
  id           Int        @id @default(autoincrement()) @map("certificateID")
  consultantID Int
  uploadedAt   DateTime   @default(now()) @map("uploaded_at")
  title        String
  consultant   Consultant @relation(fields: [consultantID], references: [id])
}

model Skills {
  id               Int                @id @default(autoincrement()) @map("skillID")
  name             String
  consultants      ConsultantSkills[]
  projects         ProjectSkills[]
}

model ConsultantSkills {
  id             Int        @id @default(autoincrement()) @map("consultantSkillsID")
  consultantID   Int
  skillID        Int
  competencyLevel String    
  experience      String
  consultant     Consultant @relation(fields: [consultantID], references: [id])
  skill          Skills     @relation(fields: [skillID], references: [id])
}
model Project {
  id                          String           @id @default(uuid()) @map("projectID")
  projectName                 String
  clientName                  String
  city                        String
  province                    String
  startDate                   DateTime
  endDate                     DateTime
  teamSize                    Int
  requiredAllocationPercentage Float
  clientBillingBudget         Float
  status                      ProjectStatus    @default(Open)
  notes                       String?
  skills                      ProjectSkills[]
  managers                    ProjectManager[]
  placements                  ProjectPlacement[]
}

enum ProjectStatus {
  Open
  InProgress
  Closed
}

model ProjectSkills {
  id        Int     @id @default(autoincrement()) @map("skillsProjectID")
  skillID   Int
  projectID String
  skill     Skills  @relation(fields: [skillID], references: [id])
  project   Project @relation(fields: [projectID], references: [id])
}

model ProjectManager {
  id        Int     @id @default(autoincrement()) @map("projectManagerID")
  userID    Int
  projectID String
  user      User    @relation(fields: [userID], references: [id])
  project   Project @relation(fields: [projectID], references: [id])
}

model ProjectPlacement {
  id               Int        @id @default(autoincrement()) @map("projectPlacementId")
  projectID        String
  consultantID     Int
  project          Project    @relation(fields: [projectID], references: [id])
  consultant       Consultant @relation(fields: [consultantID], references: [id])
}