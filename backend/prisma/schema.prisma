generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 url      = env("DATABASE_URL")
}


// ----------------------------------------Enums---------------------------------------------------

enum Role {
  ADMIN
  PROJECT_MANAGER
  CONSULTANT_MANAGER
  CONSULTANT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LOCKED
}

enum TokenType {
  ACTIVATION
  PASSWORD_RESET
  REFRESH
}

enum AuditOutcome {
  SUCCESS
  USER_NOT_FOUND
  ACCOUNT_PENDING
  ACCOUNT_SUSPENDED
  ACCOUNT_LOCKED
  FAILED_PASSWORD
}

enum CompetencyLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum PlacementStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

// ----------------------------------------Models---------------------------------------------------
model User {
  id                String     @id @default(uuid())
  fullName          String
  email             String     @unique
  passwordHash      String?
  role              Role
  status            UserStatus @default(PENDING)
  failedAttempts    Int        @default(0)
  lockedUntil       DateTime?
  isLocked          Boolean    @default(false)
  termsAcceptedAt   DateTime?
  tenantId          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tokens            Token[]
  auditLogs         authAuditLog[]
  consultant        Consultant?
  managedProjects   ProjectManager[]
  managedConsultants  ConsultantManager[]

  @@map("users")
}

model Token {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("tokens")
}

model authAuditLog {
  id        String       @id @default(uuid())
  email     String
  outcome   AuditOutcome
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  ipAddress String
  userAgent String?
  timestamp DateTime     @default(now())

  @@map("auth_audit_logs")
}

model Consultant {
  id            String             @id @default(uuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id])
  location      String
  costToCompany Float
  availability  ConsultantAvailability  @default(AVAILABLE)
  tenantId      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  skills        ConsultantSkill[]
  certificates  Certificate[]
  placements    ProjectPlacement[]
  cvFiles       CvFile[]
  managers  ConsultantManager[]

  @@map("consultants")
}

enum ConsultantAvailability {
  AVAILABLE
  UNAVAILABLE
  ON_LEAVE
}
